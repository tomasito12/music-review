# Runtime root inside the Docker container.
MUSIC_REVIEW_PROJECT_ROOT=/app

# Optional: required for semantic search, Chroma embedding updates, and LLM labels.
# OPENAI_API_KEY=

# Required for MusicBrainz, Wikidata, and Wikimedia Commons HTTP requests.
# Wikimedia returns HTTP 403 when the contact placeholder is used.
# USER_AGENT_APP=Plattenradar
# USER_AGENT_VERSION=1.0
# USER_AGENT_CONTACT=https://github.com/your-org/your-repo
